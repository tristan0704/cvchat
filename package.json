    "dotenv": "^16.6.1",
    "monaco-editor": "^0.53.0",
    "next": "^16.2.3",
    "prisma": "^6.19.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "unpdf": "^1.6.0"
  },
  "devDependencies": {
